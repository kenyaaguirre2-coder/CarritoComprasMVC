<!-- Views/Carrito/Create.cshtml -->
@model CarritoComprasMVC.Models.Producto

@{
    ViewData["Title"] = "Agregar Producto";
    string nombreComprador = Context.Session.GetString("NombreComprador") ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <!-- Tarjeta del formulario -->
                <div class="card shadow-lg border-0">
                    <div class="card-header bg-success text-white py-3">
                        <h3 class="mb-0 text-center">
                            <i class="bi bi-plus-circle me-2"></i>Agregar Nuevo Producto
                        </h3>
                    </div>

                    <div class="card-body p-4">
                        <form asp-action="Create" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                            <!-- Campo Nombre del Comprador -->
                            <div class="form-group mb-4">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-person-circle me-2 text-primary"></i>Nombre del Comprador
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-primary text-white">
                                        <i class="bi bi-person"></i>
                                    </span>
                                    <input type="text" name="nombreComprador" class="form-control"
                                           value="@nombreComprador" placeholder="Ingresa tu nombre" />
                                </div>
                                <small class="form-text text-muted">
                                    Este nombre se guardará en la sesión
                                </small>
                            </div>

                            <!-- Campo Nombre del Producto -->
                            <div class="form-group mb-4">
                                <label asp-for="Nombre" class="form-label fw-bold">
                                    <i class="bi bi-tag me-2 text-primary"></i>Nombre del Producto
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-primary text-white">
                                        <i class="bi bi-box"></i>
                                    </span>
                                    <input asp-for="Nombre" class="form-control"
                                           placeholder="Ej: Laptop, Teléfono, Libro..." />
                                </div>
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <!-- Campo Precio -->
                            <div class="form-group mb-4">
                                <label asp-for="Precio" class="form-label fw-bold">
                                    <i class="bi bi-currency-dollar me-2 text-success"></i>Precio
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-success text-white">
                                        <i class="bi bi-cash"></i>
                                    </span>
                                    <input asp-for="Precio" class="form-control"
                                           placeholder="0.00" min="0.01" step="0.01" />
                                    <span class="input-group-text">MXN</span>
                                </div>
                                <span asp-validation-for="Precio" class="text-danger small"></span>
                            </div>

                            <!-- Botones -->
                            <div class="d-flex gap-3 mt-5">
                                <button type="submit" class="btn btn-success btn-lg flex-fill">
                                    <i class="bi bi-check-circle me-2"></i>Guardar Producto
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg flex-fill">
                                    <i class="bi bi-arrow-left me-2"></i>Cancelar
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Site.js - Lógica del lado del cliente -->
    <script src="~/js/site.js"></script>
</body>
</html>