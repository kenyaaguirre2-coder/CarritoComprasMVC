<!-- Views/Carrito/Index.cshtml -->
@model IEnumerable<CarritoComprasMVC.Models.Producto>

@{
    ViewData["Title"] = "Carrito de Compras";
    decimal total = Model.Sum(p => p.Precio);
    string nombreComprador = ViewBag.NombreComprador ?? "Invitado";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Tarjeta principal -->
                <div class="card shadow-lg border-0 rounded-lg">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h2 class="mb-0">
                            <i class="bi bi-cart4 me-2"></i>Carrito de Compras
                        </h2>
                        <p class="mb-0 mt-2">Kenya Joseline Aguirre Leyva</p>
                    </div>

                    <div class="card-body p-4">
                        <!-- Mostrar nombre del comprador -->
                        <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <i class="bi bi-person-circle me-2"></i>
                                <strong>Comprador:</strong> @nombreComprador
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#cambiarCompradorModal">
                                <i class="bi bi-pencil"></i> Cambiar
                            </button>
                        </div>

                        <!-- Botones de acción -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="text-secondary mb-0">
                                <i class="bi bi-box-seam me-2"></i>Lista de Productos
                            </h4>
                            <div>
                                <a asp-action="Create" class="btn btn-success me-2">
                                    <i class="bi bi-plus-circle me-1"></i>Agregar Producto
                                </a>
                                <a asp-action="Clear" class="btn btn-outline-danger" onclick="return confirm('¿Limpiar todo el carrito?')">
                                    <i class="bi bi-eraser me-1"></i>Limpiar Carrito
                                </a>
                            </div>
                        </div>

                        <!-- Tabla de productos -->
                        @if (Model.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-bordered align-middle">
                                    <thead class="table-dark">
                                        <tr>
                                            <th scope="col" style="width: 10%">#ID</th>
                                            <th scope="col" style="width: 50%">@Html.DisplayNameFor(model => model.Nombre)</th>
                                            <th scope="col" style="width: 20%">@Html.DisplayNameFor(model => model.Precio)</th>
                                            <th scope="col" style="width: 20%">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td class="fw-bold">@item.Id</td>
                                                <td>@item.Nombre</td>
                                                <td class="text-success fw-bold">$@item.Precio.ToString("N2")</td>
                                                <td>
                                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                                       class="btn btn-danger btn-sm">
                                                        <i class="bi bi-trash me-1"></i>Eliminar
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- Tarjeta de totales -->
                            <div class="card bg-success text-white mt-4">
                                <div class="card-body">
                                    <div class="row align-items-center">
                                        <div class="col-md-6">
                                            <h5 class="mb-0">
                                                <i class="bi bi-boxes me-2"></i>
                                                Total de productos: <span class="badge bg-light text-dark fs-6">@Model.Count()</span>
                                            </h5>
                                        </div>
                                        <div class="col-md-6 text-md-end">
                                            <h4 class="mb-0">
                                                <i class="bi bi-calculator me-2"></i>
                                                Total: $<span class="fs-3">@total.ToString("N2")</span>
                                            </h4>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Mensaje cuando no hay productos -->
                            <div class="text-center py-5">
                                <i class="bi bi-cart-x display-1 text-muted"></i>
                                <h3 class="mt-3 text-muted">No hay productos en el carrito</h3>
                                <p class="text-muted mb-4">¡Comienza agregando tu primer producto!</p>
                                <a asp-action="Create" class="btn btn-primary btn-lg">
                                    <i class="bi bi-plus-circle me-2"></i>Agregar Producto
                                </a>
                            </div>
                        }
                    </div>

                    <div class="card-footer text-muted text-center bg-light">
                        <small>
                            <i class="bi bi-clock me-1"></i>
                            Última actualización: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal para cambiar nombre del comprador -->
    <div class="modal fade" id="cambiarCompradorModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-person-circle me-2"></i>Cambiar Nombre del Comprador
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="CambiarComprador" method="post">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nuevo nombre:</label>
                            <input type="text" name="nombreComprador" class="form-control" value="@nombreComprador" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Site.js - Lógica del lado del cliente -->
    <script src="~/js/site.js"></script>
</body>
</html>