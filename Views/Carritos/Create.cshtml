<!-- Views/Carrito/Create.cshtml -->
@model CarritoComprasMVC.Models.Producto

@{
    ViewData["Title"] = "Agregar Producto";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .form-container {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            border-radius: 15px;
        }
        .btn-animated {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .btn-animated:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .validation-summary-errors {
            color: #dc3545;
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            border-radius: 5px;
            padding: 10px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <!-- Tarjeta del formulario -->
                <div class="card shadow-lg border-0 form-container">
                    <div class="card-header bg-success text-white py-3">
                        <h3 class="mb-0 text-center">
                            <i class="bi bi-plus-circle me-2"></i>Agregar Nuevo Producto
                        </h3>
                    </div>

                    <div class="card-body p-4">
                        <form asp-action="Create" method="post" class="needs-validation" novalidate>
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <!-- Campo Nombre del Producto -->
                            <div class="form-group mb-4">
                                <label asp-for="Nombre" class="form-label fw-bold">
                                    <i class="bi bi-tag me-2 text-primary"></i>Nombre del Producto
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-primary text-white">
                                        <i class="bi bi-box"></i>
                                    </span>
                                    <input asp-for="Nombre" class="form-control form-control-lg"
                                           placeholder="Ej: Laptop, Teléfono, Libro..." />
                                </div>
                                <span asp-validation-for="Nombre" class="text-danger small mt-1"></span>
                                <small class="form-text text-muted">
                                    Ingresa un nombre descriptivo (entre 3 y 100 caracteres)
                                </small>
                            </div>

                            <!-- Campo Precio -->
                            <div class="form-group mb-4">
                                <label asp-for="Precio" class="form-label fw-bold">
                                    <i class="bi bi-currency-dollar me-2 text-success"></i>Precio
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-success text-white">
                                        <i class="bi bi-cash"></i>
                                    </span>
                                    <input asp-for="Precio" class="form-control form-control-lg"
                                           placeholder="0.00" min="0.01" step="0.01" />
                                    <span class="input-group-text">MXN</span>
                                </div>
                                <span asp-validation-for="Precio" class="text-danger small mt-1"></span>
                                <small class="form-text text-muted">
                                    Ingresa un precio mayor a 0 (ej: 99.99)
                                </small>
                            </div>

                            <!-- Botones de acción -->
                            <div class="d-flex gap-3 mt-5">
                                <button type="submit" class="btn btn-success btn-lg flex-fill btn-animated">
                                    <i class="bi bi-check-circle me-2"></i>Guardar Producto
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg flex-fill btn-animated">
                                    <i class="bi bi-arrow-left me-2"></i>Cancelar
                                </a>
                            </div>
                        </form>
                    </div>

                    <!-- Información adicional -->
                    <div class="card-footer bg-transparent border-0 pb-4">
                        <div class="alert alert-info mb-0" role="alert">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Nota:</strong> Todos los campos son obligatorios. El precio debe ser mayor a $0.00
                        </div>
                    </div>
                </div>

                <!-- Tarjeta de ayuda -->
                <div class="card mt-4 border-info">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-lightbulb display-6 text-warning me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Consejos para agregar productos:</h6>
                                <p class="mb-0 text-muted">
                                    Usa nombres específicos para identificar fácilmente tus productos.
                                    Verifica que el precio sea el correcto antes de guardar.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts para validación del lado del cliente -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>